<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login akun</title>
    <link rel="icon" href="../img/LogoWebsite.png">
    <!-- font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DynaPuff:wght@400..700&display=swap" rel="stylesheet">
    <!-- icon -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css">
</head>

<style>
    *, html {
        padding: 0;
        margin: 0;
        box-sizing: border-box;
    }
    body {
        background-color: #bb9e7c;
        font-family: "DynaPuff", sans-serif;
    }
    .form-login {
        background: lightblue;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1); /* Efek bayangan halus */
        width: 600px;
        height: 300px;
        justify-items: center;
        margin-top: 270px;
        margin-left: 650px;
        font-size: 20px;
    }
    form div label{
        background-color: red;
        color: aqua;
        margin-left: 120px;
    }
    form div input{
        background-color: yellow;
        font-size: 20px;
        color: green;
        margin-left: 120px;
        margin-top: 0.3rem;
        margin-bottom: 0.3rem;
    }
    form div p {
        margin-left: 120px;
    }
    #daftar {
        text-decoration: none;
        color: white;
        background-color: brown;
        transition: all;
        transition-duration: 700ms;
        border-bottom: 1px solid rgba(255, 68, 0, 0);
        font-size: 20px;
    }
    #daftar:hover{
        color: orangered;
        border-bottom: 1px solid orangered;
        background-color: rgb(45, 245, 75)  ;
    }
    .submit {
        background-color: violet;
        color: green;
        justify-items: center;
        margin-top: 20px;
        margin-left: 230px;
        width: 25px;
    }
    .submit button {
        background-color: yellow;
        color: green;
        padding: 5px 20px;
        cursor: pointer;
        transition: all;
        transition-duration: 700ms;
        border-bottom: 1px solid rgba(255, 68, 0, 0);
        font-size: 20px;
        text-decoration: none;
    }
    .submit button:hover{
        color: orangered;
        border-bottom: 1px solid orangered;
        background-color: aqua;
    }

</style>
<body>
    <form>
        <div class="form-login">
            <p>Hai, silahkan login yah ^_^ </p>
            <div class="username">
                <label>Username: </label>
                <input type="text" placeholder="Masukkan username" id="username">
            </div>
            <div class="password">
                <label>Password: </label>
                <input type="password" placeholder="Masukkan password" id="password">
            </div>

            <p>Belum punya akun? silahkan <a href="" id="daftar">daftar</a></p>
            <div class="submit">
                <button  type="submit" id="enter">Enter</button>
            </div>
        </div>
    </form>
</body>
<script>
    // --- TAMBAHKAN KODE LOGIN DI BAWAH INI ---
    const tombol = document.getElementById("enter");
    const inputUser = document.getElementById("username");
    const inputPassword = document.getElementById("password");

    async function prosesMasukAkun(event) {
        event.preventDefault(); // Menahan halaman agar tidak reload/refresh

        let User = inputUser.value;
        let Pass = inputPassword.value;

        // Kirim data ke backend Node.js
        const respon = await fetch('/prosesdata', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: User, password: Pass })
        });

        const hasil = await respon.json();

        // Cek jawaban dari server
        if (hasil.sukses) {
            // Jika database cocok, lempar ke rute /dashboard
            window.location.href = '/dashboard'; 
        } else {
            // Jika salah, tampilkan pesan error lewat alert browser
            alert(hasil.pesan);
        }
    };

    tombol.addEventListener("click", prosesMasukAkun);
</script>
</html>