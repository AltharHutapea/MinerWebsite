<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login akun</title>
    <link rel="icon" href="../img/LogoWebsite.png">
    <!-- font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DynaPuff:wght@400..700&display=swap" rel="stylesheet">
    <!-- icon -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css">
</head>

<style>
    *, html {
        padding: 0;
        margin: 0;
        box-sizing: border-box;
    }
    body {
        background-color: #bb9e7c;
        font-family: "DynaPuff", sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 20px;
    }
    form {
        width: 100%;
        max-width: 500px;
    }
    .form-login {
        background: lightblue;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1); 
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 15px;
        font-size: 20px;
    }
    .input-group {
        display: flex;
        flex-direction: column;
    }
    form div label {
        background-color: red;
        color: aqua;
        padding: 2px 5px;
        align-self: flex-start;
    }
    form div input {
        background-color: yellow;
        font-size: 20px;
        color: green;
        margin-top: 0.3rem;
        margin-bottom: 0.3rem;
        padding: 5px;
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 5px;
    }
    #daftar {
        text-decoration: none;
        color: white;
        background-color: brown;
        transition: all 700ms;
        border-bottom: 1px solid rgba(255, 68, 0, 0);
        font-size: 20px;
        padding: 0 5px;
    }
    #daftar:hover {
        color: orangered;
        border-bottom: 1px solid orangered;
        background-color: rgb(45, 245, 75);
    }
    .submit {
        display: flex;
        justify-content: center;
        margin-top: 10px;
    }
    .submit button {
        background-color: yellow;
        color: green;
        padding: 8px 30px;
        cursor: pointer;
        transition: all 700ms;
        border: 1px solid rgba(255, 68, 0, 0);
        border-radius: 5px;
        font-size: 20px;
        text-decoration: none;
    }
    .submit button:hover {
        color: orangered;
        border-bottom: 1px solid orangered;
        background-color: aqua;
    }
</style>
<body>
    <form>
        <div class="form-login">
            <p>Hai, silahkan login yah ^_^ </p>
            <div class="input-group">
                <label for="username">Username: </label>
                <input type="text" placeholder="Masukkan username" id="username">
            </div>
            
            <div class="input-group">
                <label for="password">Password: </label>
                <input type="password" placeholder="Masukkan password" id="password">
            </div>

            <p>Belum punya akun? silahkan <a href="/register" id="daftar">daftar</a></p>
            
            <div class="submit">
                <button type="submit" id="enter">Enter</button>
            </div>
        </div>
    </form>
</body>
<script>
    const tombol = document.getElementById("enter");
    const inputUser = document.getElementById("username");
    const inputPassword = document.getElementById("password");

    async function prosesMasukAkun(event) {
        event.preventDefault(); 

        let User = inputUser.value;
        let Pass = inputPassword.value;

        const respon = await fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: User, password: Pass })
        });

        const hasil = await respon.json();

        if (hasil.sukses) {
            window.location.href = '/dashboard'; 
        } else {
            alert(hasil.pesan);
        }
    };

    tombol.addEventListener("click", prosesMasukAkun);
</script>
</html>
