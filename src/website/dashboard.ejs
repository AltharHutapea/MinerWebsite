<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: #f0f2f5;
        color: #1a1a2e;
    }

    /* Layout Utama */
    .container {
        display: flex;
        min-height: 100vh;
    }

    /* Sidebar Samping Kiri */
    .sidebar {
        width: 280px;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        position: fixed;
        height: 100vh;
        display: flex; /* Ditambahkan agar struktur memanjang ke bawah */
        flex-direction: column; /* Mengatur susunan isi secara vertikal */
        justify-content: space-between; /* Memisah menu utama dengan footer bawah */
        transition: all 0.3s;
    }

    /* Pembungkus Menu Atas */
    .sidebar-menu-wrapper {
        overflow-y: auto;
        flex: 1;
    }

    .sidebar-header {
        padding: 25px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        text-align: center;
    }

    .sidebar-header h2 {
        font-size: 1.5rem;
        margin-bottom: 5px;
    }

    .sidebar-header p {
        font-size: 0.8rem;
        opacity: 0.7;
    }

    .nav-menu {
        padding: 20px 0;
    }

    .nav-item {
        padding: 12px 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        transition: all 0.3s;
        cursor: pointer;
    }

    .nav-item:hover, .nav-item.active {
        background: rgba(255,255,255,0.1);
        color: white;
        border-left: 3px solid #e94560;
    }

    .nav-item i {
        width: 20px;
        font-size: 1.1rem;
    }

    /* Pembungkus Tombol Keluar di Kiri Bawah */
    .sidebar-footer {
        padding: 15px 0;
        border-top: 1px solid rgba(255,255,255,0.1);
        background: rgba(0, 0, 0, 0.2);
    }

    /* Gaya Khusus Tombol Keluar */
    .btn-logout {
        color: #ff4d4d;
        font-weight: 600;
    }

    .btn-logout:hover {
        background: rgba(255, 77, 77, 0.1);
        color: #ff6666;
        border-left: 3px solid #ff4d4d;
    }

    /* area Konten Utama */
    .main-content {
        flex: 1;
        margin-left: 280px;
        padding: 20px;
    }

    /* Atasan Header */
    .top-header {
        background: white;
        border-radius: 12px;
        padding: 15px 25px;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 600;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: #e94560;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
    }

    /* Responsif Layar Kecil */
    @media (max-width: 768px) {
        .sidebar {
            transform: translateX(-100%);
            z-index: 1000;
        }
        .main-content {
            margin-left: 0;
        }
    }
</style>
</head>
<body>
    <div class="container">
        <!-- Sidebar Samping Kiri -->
        <div class="sidebar">
            
            <!-- Bagian Atas Sidebar (Menu Navigasi) -->
            <div class="sidebar-menu-wrapper">
                <div class="sidebar-header">
                    <h2><i class="fas fa-book"></i> Miner Website</h2>
                    <p>Dashboard</p>
                </div>
                <div class="nav-menu">
                    <a class="nav-item active"><i class="fas fa-chart-line"></i>Dashboard</a>
                    <a class="nav-item"><i class="fas fa-book-open"></i> Buku</a>
                    <a class="nav-item"><i class="fas fa-tags"></i> Kategori</a>
                    <a class="nav-item"><i class="fas fa-hand-holding"></i> Peminjaman</a>
                    <a class="nav-item"><i class="fas fa-wallet"></i> Transaksi</a>
                    <a class="nav-item"><i class="fas fa-users"></i> Pengguna</a>
                    <a class="nav-item"><i class="fas fa-heart"></i> Wishlist</a>
                </div>
            </div>

            <!-- Bagian Bawah Sidebar (Tombol Keluar) -->
            <div class="sidebar-footer">
                <!-- Alamat diarahkan ke /logout untuk memproses hapus session di server -->
                <a href="/logout" class="nav-item btn-logout">
                    <i class="fas fa-sign-out-alt"></i> Keluar
                </a>
            </div>

        </div>

        <div class="main-content">
            <header class="top-header">
                <div class="page-title"> Hai <%= username %>!</div>
                <div class="user-info">
                    <p> <%= username %> </p>
                    <div class="user-avatar">
                        <%= username.charAt(0).toUpperCase() %>
                    </div>
                </div>
            </header>

            <!-- ISI KONTEN COSONG DI BAWAH INI BISA KAMU ISI SENDIRI NANTI -->
            <div class="content-body">
                <!-- Taruh tabel atau data miner kamu di sini -->
            </div>
        </div>
    </div>
</body>
<script>
    window.addEventListener('pageshow', function (event) {
        if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
            window.location.reload();
        }
    });
</script>
</html>
