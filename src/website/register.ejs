<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>register akun</title>
    <link rel="icon" href="/LogoWebsite.png">
    <!-- font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DynaPuff:wght@400..700&display=swap" rel="stylesheet">
    <!-- icon -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css">
</head>

<style>
    *, html {
        padding: 0;
        margin: 0;
        box-sizing: border-box;
    }
    body {
        background-color: #bb9e7c;
        font-family: "DynaPuff", sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 20px;
    }
    form {
        width: 100%;
        max-width: 500px;
    }
    .form-login {
        background: lightblue;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1); 
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 15px;
        font-size: 20px;
    }
    .input-group {
        display: flex;
        flex-direction: column;
    }
    form div label {
        background-color: red;
        color: aqua;
        padding: 2px 5px;
        align-self: flex-start;
    }
    form div input {
        background-color: yellow;
        font-size: 20px;
        color: green;
        margin-top: 0.3rem;
        margin-bottom: 0.3rem;
        padding: 8px;
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 5px;
    }
    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    .password-wrapper input {
        padding-right: 40px;
    }
    #togglePassword {
        cursor: pointer;
        color: black;
        font-size: 24px;
        position: absolute;
        right: 10px;
    }
    
    .form-login p a {
        color: blue;
    }
    .submit {
        display: flex;
        justify-content: center;
        margin-top: 10px;
    }
    .submit button {
        background-color: yellow;
        color: green;
        padding: 8px 30px;
        cursor: pointer;
        transition: all 700ms;
        border: 1px solid rgba(255, 68, 0, 0);
        border-radius: 5px;
        font-size: 20px;
    }
    .submit button:hover {
        color: orangered;
        border-bottom: 1px solid orangered;
        background-color: aqua;
    }
</style>
<body>
    <form>
        <div class="form-login">
            <div class="input-group">
                <label>Username: </label>
                <input type="text" placeholder="Masukkan username" id="username">
            </div>
            <div class="input-group">
                <label>Email: </label>
                <input type="email" placeholder="example@gmail.com" id="email">
            </div>
            <div class="input-group">
                <label>Password: </label>
                <div class="password-wrapper">
                    <input type="password" placeholder="Masukkan password" id="password" >
                    <i class="ph ph-eye" id="togglePassword"></i>
                </div>
            </div>

            <p>Sudah punya akun? silahkan <a href="/">login</a></p>
            
            <div class="submit">
                <button type="submit" id="masuk">Enter</button>
            </div>
        </div>
    </form>
</body>
<script>
    const passwordInput = document.getElementById("password");
    const togglePassword = document.getElementById("togglePassword");

    togglePassword.addEventListener("click", function () {
        const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
        passwordInput.setAttribute("type", type);
        
        this.classList.toggle("ph-eye");
        this.classList.toggle("ph-eye-slash");
    });

    const tombolMasuk = document.getElementById('masuk');
    const re_username = document.getElementById('username');
    const re_email = document.getElementById('email');
    const re_password = document.getElementById('password');

    async function prosesBuatAkun(event) {
        event.preventDefault();
        
        let Username = re_username.value;
        let Email = re_email.value;
        let Password = re_password.value;
        if (!Email.endsWith('@gmail.com')) {
            alert("Pendaftaran gagal! Email harus diakhiri dengan @gmail.com");
            return;
    }
        try {
            const respons = await fetch('/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: Username, password: Password, email: Email })
            });

            const hasil = await respons.json();

            if (hasil.sukses) {
                alert(hasil.pesan || "Pendaftaran berhasil!"); 
                window.location.href = '/';
            } else {
                alert(hasil.pesan);
            }
        } catch (error) {
            console.error("Gagal mengirim data:", error);
            alert("Terjadi masalah koneksi ke server.");
        }
    };
    
    tombolMasuk.addEventListener("click", prosesBuatAkun);
</script>
</html>
